                  "ProofIdentityType": {
                    "type": "string"
                  },
                  "WorkStatus": {
                    "type": "boolean"
                  },
                  "ProofIdentityFile": {
                    "type": "string",
                    "format": "binary"
                  },
                  "PswCertificateFile": {
                    "type": "string",
                    "format": "binary"
                  },
                  "CVFile": {
                    "type": "string",
                    "format": "binary"
                  },
                  "ImmunizationRecordFile": {
                    "type": "string",
                    "format": "binary"
                  },
                  "CriminalRecordFile": {
                    "type": "string",
                    "format": "binary"
                  },
                  "FirstAidOrCPRFile": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "ProofIdentityType": {
                  "style": "form"
                },
                "WorkStatus": {
                  "style": "form"
                },
                "ProofIdentityFile": {
                  "style": "form"
                },
                "PswCertificateFile": {
                  "style": "form"
                },
                "CVFile": {
                  "style": "form"
                },
                "ImmunizationRecordFile": {
                  "style": "form"
                },
                "CriminalRecordFile": {
                  "style": "form"
                },
                "FirstAidOrCPRFile": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
