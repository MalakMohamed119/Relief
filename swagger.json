  "components": {
    "schemas": {
      "AcceptShiftDto": {
        "type": "object",
        "properties": {
          "shiftId": {
            "type": "string",
            "format": "uuid"
          },
          "jobRequestItemId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      },
      "AddressDTO": {
        "required": [
          "apartmentNumber",
          "city",
          "country",
          "postalCode",
          "state",
          "street"
        ],
        "type": "object",
        "properties": {
          "apartmentNumber": {
            "type": "integer",
            "format": "int32"
          },
          "street": {
            "minLength": 1,
            "type": "string"
          },
          "city": {
            "minLength": 1,
            "type": "string"
          },
          "state": {
            "minLength": 1,
            "type": "string"
          },
          "postalCode": {
            "minLength": 1,
            "type": "string"
          },
          "country": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "AdminRejectDto": {
        "required": [
          "reason"
        ],
        "type": "object",
        "properties": {
          "reason": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ApplyToOfferDto": {
        "required": [
          "offerId"
        ],
        "type": "object",
        "properties": {
          "offerId": {
            "type": "string",
            "format": "uuid"
          },
          "shiftIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AuthResponseDTO": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "nullable": true
          },
          "expiresAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "nullable": true
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      },
      "CancelApplicationDto": {
        "type": "object",
        "properties": {
          "jobRequestItemId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      },
      "CreateJobOfferDto": {
        "required": [
          "address",
          "description",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "address": {
            "minLength": 1,
            "type": "string"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "hourlyRate": {
            "type": "number",
            "format": "double"
          },
          "shifts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateOfferShiftDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateOfferShiftDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "startTime": {
